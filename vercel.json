{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/corporativo", "destination": "/pages/corporativo.html" },
    { "source": "/dialisis", "destination": "/pages/dialisis.html" },
    { "source": "/embajadas", "destination": "/pages/embajadas.html" },
    { "source": "/contacto", "destination": "/pages/contacto.html" }
  ]
}
